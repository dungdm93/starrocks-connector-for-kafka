{
  "name": "starrocks-sink-connector",
  "config": {
    "connector.class": "com.starrocks.connector.kafka.StarRocksSinkConnector",
    "tasks.max": "1",
    "topics": "dvdrental.public.payment",
    "starrocks.topic2table.map": "dvdrental.public.payment:payment",
    "starrocks.http.url": "localhost:8030",
    "starrocks.database.name": "example_db",
    "starrocks.username": "root",
    "starrocks.password": "",
    "starrocks.envelope": "debezium",
    "starrocks.delete.enabled": "true",
    "sink.properties.format": "json",
    "sink.properties.strip_outer_array": "true",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://localhost:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://localhost:8081"
  }
}